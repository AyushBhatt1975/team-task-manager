{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npm run build",
    "env": {
      "NIXPACKS_NODE_VERSION": "20",
      "NIXPACKS_INSTALL_CMD": "npm install"
    }
  },
  "deploy": {
    "startCommand": "npx serve -s dist -p $PORT",
    "healthcheckPath": "/",
    "healthcheckTimeout": 30
  }
}
